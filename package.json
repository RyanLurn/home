{
  "name": "home",
  "type": "module",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "configs/*",
      "packages/*",
      "scripts/*"
    ],
    "catalog": {
      "@t3-oss/env-core": "^0.13.10",
      "eslint": "^10.0.3",
      "typescript": "^5.9.3",
      "zod": "^4.3.6"
    },
    "catalogs": {
      "ai": {
        "ai": "^6.0.116"
      },
      "tanstack": {
        "@tanstack/react-router": "^1.166.7",
        "@tanstack/react-start": "^1.166.7"
      },
      "types": {
        "@types/bun": "^1.3.10",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3"
      },
      "ui": {
        "lucide-react": "^0.577.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "tailwindcss": "^4.2.1"
      },
      "build": {
        "@tailwindcss/vite": "^4.2.1",
        "@vitejs/plugin-react": "^6.0.1",
        "babel-plugin-react-compiler": "^1.0.0",
        "tsdown": "^0.21.2",
        "vite": "^8.0.0"
      }
    }
  },
  "scripts": {
    "check-types": "bun run --parallel --workspaces --if-present --no-exit-on-error check-types",
    "lint": "bun run --parallel --workspaces --if-present --no-exit-on-error lint",
    "lint:fix": "bun run --parallel --workspaces --if-present --no-exit-on-error lint:fix",
    "format": "bunx prettier . --write",
    "format:check": "bunx prettier . --check",
    "check": "bun run check-types && bun run lint && bun run format:check",
    "core:build": "bun --filter @home/core build --log-level error"
  },
  "devDependencies": {
    "prettier": "3.8.1",
    "prettier-plugin-curly": "0.4.1",
    "prettier-plugin-tailwindcss": "0.7.2"
  },
  "packageManager": "bun@1.3.10"
}
