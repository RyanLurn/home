  "devDependencies": {
    "@home/eslint": "workspace:*",
    "@home/typescript": "workspace:*",
    "@types/bun": "catalog:types",
    "eslint": "catalog:",
    "tsdown": "catalog:build",
    "typescript": "catalog:"
  }
}
